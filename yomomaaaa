<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sri Rithik Srinivash — Mechanical Engineer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@300;400;500;600&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root {
  --cyan: #00E5FF;
  --cyan-dim: rgba(0,229,255,0.12);
  --cyan-glow: rgba(0,229,255,0.35);
  --orange: #FF6B35;
  --orange-dim: rgba(255,107,53,0.12);
  --bg: #040810;
  --surface: #080D1A;
  --surface2: #0D1525;
  --border: rgba(0,229,255,0.15);
  --text: #C8D8F0;
  --muted: rgba(200,216,240,0.45);
  --white: #EEF4FF;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Rajdhani', sans-serif;
  font-weight: 400;
  overflow-x: hidden;
  cursor: none;
}

/* ── CURSOR ── */
.cur { width:8px; height:8px; background:var(--cyan); border-radius:50%; position:fixed; top:0; left:0; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); transition:transform 0.12s, background 0.2s; }
.cur-ring { width:32px; height:32px; border:1px solid var(--cyan-glow); border-radius:50%; position:fixed; top:0; left:0; pointer-events:none; z-index:9998; transform:translate(-50%,-50%); transition:all 0.4s cubic-bezier(0.23,1,0.32,1); }

/* ── CIRCUIT BG ── */
.circuit-bg {
  position:fixed; inset:0; z-index:0; pointer-events:none;
  background-image:
    linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
  background-size: 50px 50px;
}
.circuit-bg::after {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, rgba(0,229,255,0.06), transparent),
    radial-gradient(ellipse 40% 40% at 100% 100%, rgba(255,107,53,0.05), transparent);
}

/* ── NAV ── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:500;
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 60px;
  transition:background 0.4s, border-color 0.4s;
  border-bottom: 1px solid transparent;
}
nav.scrolled {
  background: rgba(4,8,16,0.92);
  backdrop-filter: blur(20px);
  border-color: var(--border);
}
.nav-logo {
  font-family:'Orbitron', monospace;
  font-size:14px; font-weight:700;
  letter-spacing:0.15em;
  color:var(--cyan);
  text-decoration:none;
}
.nav-logo span { color:var(--orange); }
.nav-links { display:flex; gap:36px; list-style:none; }
.nav-links a {
  font-size:12px; letter-spacing:0.15em; text-transform:uppercase;
  color:var(--muted); text-decoration:none;
  transition:color 0.3s; font-family:'IBM Plex Mono', monospace;
}
.nav-links a:hover { color:var(--cyan); }
.nav-badge {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.12em;
  color:var(--cyan); border:1px solid var(--border);
  padding:8px 18px; text-decoration:none;
  transition:all 0.3s; text-transform:uppercase;
}
.nav-badge:hover { background:var(--cyan-dim); border-color:var(--cyan); }

/* ── HERO ── */
.hero {
  min-height:100vh;
  display:flex; align-items:center;
  padding:100px 60px 60px;
  position:relative; overflow:hidden;
}
.hero-left { flex:1; max-width:680px; position:relative; z-index:2; }
.hero-right {
  flex:0 0 340px;
  display:flex; flex-direction:column; align-items:center;
  position:relative; z-index:2;
}

.status-pill {
  display:inline-flex; align-items:center; gap:10px;
  font-family:'IBM Plex Mono', monospace;
  font-size:11px; letter-spacing:0.15em; text-transform:uppercase;
  color:var(--cyan); border:1px solid var(--border);
  padding:8px 18px; margin-bottom:32px;
  background:var(--cyan-dim);
  opacity:0; animation:fadeUp 0.8s 0.2s forwards;
}
.status-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--cyan);
  box-shadow:0 0 8px var(--cyan);
  animation:blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.hero-name {
  font-family:'Orbitron', monospace;
  font-size:clamp(36px,6vw,72px);
  font-weight:900;
  line-height:1.05;
  letter-spacing:0.02em;
  color:var(--white);
  margin-bottom:8px;
  opacity:0; animation:fadeUp 0.9s 0.4s forwards;
}
.hero-name .glow { color:var(--cyan); text-shadow:0 0 30px var(--cyan-glow), 0 0 60px rgba(0,229,255,0.15); }

.hero-tag {
  font-family:'IBM Plex Mono', monospace;
  font-size:13px; letter-spacing:0.1em;
  color:var(--orange); margin-bottom:28px;
  opacity:0; animation:fadeUp 0.9s 0.55s forwards;
}

.hero-desc {
  font-size:17px; line-height:1.8; color:var(--muted);
  max-width:520px; margin-bottom:44px;
  opacity:0; animation:fadeUp 0.9s 0.7s forwards;
}
.hero-desc strong { color:var(--cyan); font-weight:600; }

.hero-actions {
  display:flex; gap:16px; align-items:center;
  opacity:0; animation:fadeUp 0.9s 0.85s forwards;
}
.btn-neon {
  display:inline-flex; align-items:center; gap:10px;
  background:transparent; border:1px solid var(--cyan);
  color:var(--cyan); padding:14px 32px;
  font-family:'Orbitron', monospace;
  font-size:11px; font-weight:600; letter-spacing:0.18em;
  text-transform:uppercase; text-decoration:none;
  position:relative; overflow:hidden;
  transition:all 0.4s; cursor:none;
}
.btn-neon::before {
  content:''; position:absolute; inset:0;
  background:var(--cyan-dim); transform:scaleX(0);
  transform-origin:left; transition:transform 0.4s cubic-bezier(0.23,1,0.32,1);
}
.btn-neon:hover { box-shadow:0 0 24px var(--cyan-glow); }
.btn-neon:hover::before { transform:scaleX(1); }
.btn-neon span { position:relative; z-index:1; }

.btn-outline {
  display:inline-flex; align-items:center; gap:10px;
  border:1px solid var(--border); color:var(--muted);
  padding:14px 32px;
  font-family:'IBM Plex Mono', monospace;
  font-size:11px; letter-spacing:0.15em; text-transform:uppercase;
  text-decoration:none; transition:all 0.3s; cursor:none;
}
.btn-outline:hover { border-color:var(--orange); color:var(--orange); }

/* AVATAR RING */
.avatar-ring {
  width:240px; height:240px;
  border-radius:50%;
  border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  position:relative;
  margin-bottom:32px;
  opacity:0; animation:fadeUp 1s 0.6s forwards;
}
.avatar-ring::before {
  content:''; position:absolute; inset:-8px;
  border-radius:50%;
  border:1px solid rgba(0,229,255,0.08);
  animation:spin 12s linear infinite;
}
.avatar-ring::after {
  content:''; position:absolute; inset:-16px;
  border-radius:50%;
  border:1px dashed rgba(0,229,255,0.05);
  animation:spin 20s linear infinite reverse;
}
@keyframes spin { to { transform:rotate(360deg); } }

.avatar-inner {
  width:200px; height:200px; border-radius:50%;
  background:linear-gradient(135deg, var(--surface2), var(--surface));
  border:2px solid var(--cyan-dim);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  box-shadow:0 0 60px rgba(0,229,255,0.08);
}
.avatar-initials {
  font-family:'Orbitron', monospace;
  font-size:52px; font-weight:900;
  background:linear-gradient(135deg, var(--cyan), var(--orange));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  line-height:1;
}
.avatar-label {
  font-family:'IBM Plex Mono', monospace;
  font-size:9px; letter-spacing:0.2em; color:var(--muted);
  text-transform:uppercase; margin-top:8px;
}

.hero-mini-stats {
  display:flex; gap:28px;
  opacity:0; animation:fadeUp 1s 0.8s forwards;
}
.mini-stat { text-align:center; }
.mini-stat .n {
  font-family:'Orbitron', monospace;
  font-size:22px; font-weight:700; color:var(--cyan);
  display:block;
}
.mini-stat .l {
  font-family:'IBM Plex Mono', monospace;
  font-size:9px; color:var(--muted); letter-spacing:0.15em; text-transform:uppercase;
}

/* SCANNER LINE */
.scanner {
  position:absolute; left:0; right:0; height:1px;
  background:linear-gradient(90deg, transparent, var(--cyan), transparent);
  animation:scan 6s ease-in-out infinite;
  opacity:0.4; pointer-events:none;
}
@keyframes scan {
  0%,100%{top:10%} 50%{top:90%}
}

/* ── SHARED SECTION ── */
section { padding:100px 60px; position:relative; z-index:2; }
.sec-header { margin-bottom:60px; }
.sec-label {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.3em; text-transform:uppercase;
  color:var(--cyan); display:flex; align-items:center; gap:14px; margin-bottom:14px;
}
.sec-label::before { content:'//'; color:var(--orange); }
.sec-title {
  font-family:'Orbitron', monospace;
  font-size:clamp(28px,4vw,44px);
  font-weight:700; color:var(--white);
  letter-spacing:0.04em;
}
.sec-title .acc { color:var(--cyan); }

/* ── ABOUT ── */
.about-grid { display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:start; }
.about-text {
  font-size:17px; line-height:1.9; color:var(--muted);
}
.about-text strong { color:var(--cyan); font-weight:600; }
.about-text p { margin-bottom:20px; }

.about-cards { display:flex; flex-direction:column; gap:16px; }
.about-card {
  border:1px solid var(--border);
  background:var(--surface);
  padding:24px 28px;
  position:relative; overflow:hidden;
  transition:border-color 0.4s, background 0.4s;
}
.about-card::before {
  content:''; position:absolute; left:0; top:0; bottom:0; width:2px;
  background:var(--cyan); transform:scaleY(0); transform-origin:bottom;
  transition:transform 0.4s cubic-bezier(0.23,1,0.32,1);
}
.about-card:hover::before { transform:scaleY(1); }
.about-card:hover { border-color:var(--cyan-glow); background:var(--surface2); }
.ac-label {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.2em; color:var(--orange); text-transform:uppercase; margin-bottom:8px;
}
.ac-val { font-size:16px; font-weight:600; color:var(--white); }

/* ── SKILLS ── */
.skills-section { background:var(--surface); }
.skills-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--border); border:1px solid var(--border); }

.skill-block { background:var(--bg); padding:44px 36px; }
.skill-block-title {
  font-family:'Orbitron', monospace; font-size:13px;
  font-weight:600; letter-spacing:0.15em; color:var(--orange);
  text-transform:uppercase; margin-bottom:32px;
  display:flex; align-items:center; gap:12px;
}
.skill-block-title .icon { font-size:18px; }

.skill-item { margin-bottom:24px; }
.skill-name {
  font-size:14px; letter-spacing:0.08em; color:var(--text);
  display:flex; justify-content:space-between; margin-bottom:8px;
}
.skill-pct { font-family:'IBM Plex Mono', monospace; font-size:12px; color:var(--cyan); }
.skill-bar {
  height:2px; background:rgba(0,229,255,0.1);
  position:relative; overflow:hidden;
}
.skill-fill {
  height:100%; background:linear-gradient(90deg, var(--cyan), var(--orange));
  width:0%; transition:width 1.4s cubic-bezier(0.23,1,0.32,1);
  position:relative;
}
.skill-fill::after {
  content:''; position:absolute; right:0; top:-3px;
  width:6px; height:6px; border-radius:50%;
  background:var(--cyan); box-shadow:0 0 8px var(--cyan);
}

.soft-pill {
  display:inline-flex; align-items:center; gap:8px;
  border:1px solid var(--border); padding:10px 16px;
  font-size:13px; color:var(--text); margin:6px 4px 0 0;
  transition:all 0.3s; background:var(--surface);
}
.soft-pill::before { content:'▸'; color:var(--cyan); font-size:10px; }
.soft-pill:hover { border-color:var(--cyan); color:var(--cyan); background:var(--cyan-dim); }

/* ── EXPERIENCE ── */
.timeline { position:relative; padding-left:40px; }
.timeline::before {
  content:''; position:absolute; left:0; top:0; bottom:0; width:1px;
  background:linear-gradient(to bottom, var(--cyan), rgba(0,229,255,0.05));
}
.timeline-item { position:relative; margin-bottom:60px; }
.timeline-dot {
  position:absolute; left:-48px; top:4px;
  width:14px; height:14px; border-radius:50%;
  border:2px solid var(--cyan); background:var(--bg);
  box-shadow:0 0 16px var(--cyan-glow);
}
.timeline-dot::after {
  content:''; position:absolute; inset:3px; border-radius:50%;
  background:var(--cyan); animation:blink 2s infinite;
}
.timeline-card {
  border:1px solid var(--border); background:var(--surface);
  padding:36px 40px; transition:border-color 0.4s, background 0.4s;
  position:relative; overflow:hidden;
}
.timeline-card:hover { border-color:var(--cyan); background:var(--surface2); }
.timeline-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg, var(--cyan), transparent);
  opacity:0; transition:opacity 0.4s;
}
.timeline-card:hover::before { opacity:1; }
.tc-meta {
  display:flex; align-items:center; gap:16px; margin-bottom:14px;
  flex-wrap:wrap;
}
.tc-badge {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
  color:var(--orange); border:1px solid rgba(255,107,53,0.3);
  padding:4px 12px; background:var(--orange-dim);
}
.tc-date {
  font-family:'IBM Plex Mono', monospace;
  font-size:11px; color:var(--muted); letter-spacing:0.1em;
}
.tc-title {
  font-family:'Orbitron', monospace;
  font-size:20px; font-weight:700; color:var(--white);
  letter-spacing:0.05em; margin-bottom:8px;
}
.tc-org {
  font-size:14px; color:var(--cyan); margin-bottom:16px;
  font-family:'IBM Plex Mono', monospace; font-size:13px;
}
.tc-desc { font-size:16px; line-height:1.8; color:var(--muted); }

.tc-tags { display:flex; flex-wrap:wrap; gap:8px; margin-top:20px; }
.tc-tag {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.12em; text-transform:uppercase;
  color:var(--cyan-glow); border:1px solid rgba(0,229,255,0.15);
  padding:4px 12px; background:var(--cyan-dim);
}

/* ── HOBBIES ── */
.hobbies-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; }
.hobby-card {
  border:1px solid var(--border); background:var(--surface);
  padding:40px 28px; text-align:center;
  transition:all 0.4s; position:relative; overflow:hidden;
  cursor:default;
}
.hobby-card::before {
  content:''; position:absolute; inset:0;
  background:radial-gradient(circle at 50% 80%, var(--cyan-dim), transparent 70%);
  opacity:0; transition:opacity 0.4s;
}
.hobby-card:hover { border-color:var(--cyan); transform:translateY(-6px); }
.hobby-card:hover::before { opacity:1; }
.hobby-icon { font-size:40px; margin-bottom:16px; display:block; }
.hobby-name {
  font-family:'Orbitron', monospace;
  font-size:13px; font-weight:600; letter-spacing:0.1em;
  color:var(--white); margin-bottom:10px; text-transform:uppercase;
}
.hobby-desc { font-size:13px; color:var(--muted); line-height:1.6; }

/* ── CONTACT ── */
.contact-section { background:var(--surface); }
.contact-grid { display:grid; grid-template-columns:1fr 1.4fr; gap:80px; align-items:start; }
.contact-left {}
.contact-info { margin-top:40px; display:flex; flex-direction:column; gap:20px; }
.contact-line {
  display:flex; align-items:center; gap:16px;
  border:1px solid var(--border); padding:18px 24px;
  background:var(--bg); transition:border-color 0.3s;
}
.contact-line:hover { border-color:var(--cyan); }
.cl-icon { font-size:18px; width:24px; text-align:center; }
.cl-label {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.2em; color:var(--orange); text-transform:uppercase;
}
.cl-val { font-size:14px; color:var(--text); }

/* FORM */
.contact-form { display:flex; flex-direction:column; gap:20px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.form-group { display:flex; flex-direction:column; gap:8px; }
.form-group label {
  font-family:'IBM Plex Mono', monospace;
  font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
  color:var(--cyan);
}
.form-group input,
.form-group textarea {
  background:var(--bg); border:1px solid var(--border);
  color:var(--text); padding:14px 18px;
  font-family:'Rajdhani', sans-serif; font-size:15px;
  outline:none; transition:border-color 0.3s, box-shadow 0.3s;
  resize:none;
}
.form-group input:focus,
.form-group textarea:focus {
  border-color:var(--cyan);
  box-shadow:0 0 16px rgba(0,229,255,0.08);
}
.form-group input::placeholder,
.form-group textarea::placeholder { color:rgba(200,216,240,0.2); }
.form-submit {
  align-self:flex-start;
  background:transparent; border:1px solid var(--cyan);
  color:var(--cyan); padding:15px 40px;
  font-family:'Orbitron', monospace; font-size:11px;
  font-weight:600; letter-spacing:0.2em; text-transform:uppercase;
  cursor:pointer; position:relative; overflow:hidden;
  transition:all 0.4s;
}
.form-submit::before {
  content:''; position:absolute; inset:0;
  background:var(--cyan-dim); transform:scaleX(0); transform-origin:left;
  transition:transform 0.4s cubic-bezier(0.23,1,0.32,1);
}
.form-submit:hover { box-shadow:0 0 24px var(--cyan-glow); }
.form-submit:hover::before { transform:scaleX(1); }
.form-submit span { position:relative; z-index:1; }
.form-note {
  font-family:'IBM Plex Mono', monospace;
  font-size:11px; color:var(--muted); line-height:1.7;
}

/* ── FOOTER ── */
footer {
  border-top:1px solid var(--border);
  padding:40px 60px;
  display:flex; justify-content:space-between; align-items:center;
  position:relative; z-index:2;
  background:var(--bg);
}
.footer-logo {
  font-family:'Orbitron', monospace; font-size:14px; font-weight:700;
  color:var(--cyan); text-decoration:none;
}
.footer-copy {
  font-family:'IBM Plex Mono', monospace;
  font-size:11px; color:var(--muted); letter-spacing:0.1em;
}
.footer-back {
  font-family:'IBM Plex Mono', monospace;
  font-size:11px; color:var(--muted); text-decoration:none;
  letter-spacing:0.1em; transition:color 0.3s;
  display:flex; align-items:center; gap:8px;
}
.footer-back:hover { color:var(--cyan); }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(28px); }
  to   { opacity:1; transform:translateY(0); }
}
.reveal {
  opacity:0; transform:translateY(40px);
  transition:opacity 0.9s cubic-bezier(0.23,1,0.32,1), transform 0.9s cubic-bezier(0.23,1,0.32,1);
}
.reveal.visible { opacity:1; transform:translateY(0); }
.reveal-delay-1 { transition-delay:0.1s; }
.reveal-delay-2 { transition-delay:0.2s; }
.reveal-delay-3 { transition-delay:0.3s; }

/* GLITCH */
.glitch {
  position:relative;
}
.glitch::before, .glitch::after {
  content:attr(data-text);
  position:absolute; left:0; top:0;
  font-family:'Orbitron', monospace;
  font-weight:900;
  width:100%; height:100%;
  background:transparent;
}
.glitch::before {
  color:var(--cyan); clip-path:polygon(0 0,100% 0,100% 45%,0 45%);
  animation:glitch1 4s infinite; opacity:0.4;
}
.glitch::after {
  color:var(--orange); clip-path:polygon(0 55%,100% 55%,100% 100%,0 100%);
  animation:glitch2 4s infinite; opacity:0.3;
}
@keyframes glitch1 {
  0%,90%,100%{transform:translate(0)} 93%{transform:translate(-3px,1px)} 96%{transform:translate(2px,-1px)}
}
@keyframes glitch2 {
  0%,90%,100%{transform:translate(0)} 93%{transform:translate(3px,-1px)} 96%{transform:translate(-2px,2px)}
}

/* SCROLLBAR */
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:var(--bg); }
::-webkit-scrollbar-thumb { background:var(--cyan-glow); }
</style>
</head>
<body>

<div class="cur" id="cur"></div>
<div class="cur-ring" id="curRing"></div>
<div class="circuit-bg"></div>
<div class="scanner"></div>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">SRS<span>.</span>dev</a>
  <ul class="nav-links">
